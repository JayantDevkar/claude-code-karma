# Karma Radio Hook Configuration for Claude Code
#
# This file configures Claude Code hooks to report agent status to the karma radio system.
# Copy this file to your project's .claude/hooks.yaml to enable real-time agent monitoring.
#
# Prerequisites:
# - karma-logger installed globally (npm link)
# - karma dashboard running with --radio flag
#
# Environment Variables (set by Claude Code):
# - KARMA_AGENT_ID: Unique identifier for this agent
# - KARMA_SESSION_ID: Root session identifier
# - KARMA_PARENT_ID: Parent agent ID (for hierarchy tracking)
# - KARMA_AGENT_TYPE: Agent type (task, explore, plan, etc.)
# - KARMA_MODEL: Model name (claude-sonnet-4, claude-opus-4, etc.)
#
# Valid States:
# - pending: Agent registered but not yet active (idle)
# - active: Agent is actively processing (working)
# - waiting: Agent blocked on dependency
# - completed: Agent finished successfully (done)
# - failed: Agent encountered an error
# - cancelled: Agent was cancelled

hooks:
  # Report when tool execution starts
  # Sets status to "active" with the tool name as the message
  PreToolUse:
    - command: |
        karma radio set-status active --message "Using $TOOL_NAME" 2>/dev/null || true
      env:
        KARMA_AGENT_ID: "{{agentId}}"
        KARMA_SESSION_ID: "{{sessionId}}"
        KARMA_PARENT_ID: "{{parentAgentId}}"
        KARMA_AGENT_TYPE: "{{agentType}}"
        KARMA_MODEL: "{{model}}"
      timeout: 5000
      on_error: ignore

  # Report completion after each tool use
  # Reports progress and signals tool completion
  PostToolUse:
    - command: |
        karma radio report-progress 0 --message "Completed $TOOL_NAME" 2>/dev/null || true
      env:
        KARMA_AGENT_ID: "{{agentId}}"
        KARMA_SESSION_ID: "{{sessionId}}"
        KARMA_PARENT_ID: "{{parentAgentId}}"
        KARMA_AGENT_TYPE: "{{agentType}}"
        KARMA_MODEL: "{{model}}"
      timeout: 5000
      on_error: ignore

  # Report session start
  # Registers the agent with pending status when session begins
  SessionStart:
    - command: |
        karma radio set-status pending --message "Session started" 2>/dev/null || true
      env:
        KARMA_AGENT_ID: "{{sessionId}}"
        KARMA_SESSION_ID: "{{sessionId}}"
        KARMA_PARENT_ID: "{{parentAgentId}}"
        KARMA_AGENT_TYPE: "{{agentType}}"
        KARMA_MODEL: "{{model}}"
      timeout: 5000
      on_error: ignore

  # Report session end
  # Sets status to "completed" when session finishes successfully
  Stop:
    - command: |
        karma radio set-status completed --message "Session completed" 2>/dev/null || true
      env:
        KARMA_AGENT_ID: "{{agentId}}"
        KARMA_SESSION_ID: "{{sessionId}}"
        KARMA_PARENT_ID: "{{parentAgentId}}"
        KARMA_AGENT_TYPE: "{{agentType}}"
        KARMA_MODEL: "{{model}}"
      timeout: 5000
      on_error: ignore
