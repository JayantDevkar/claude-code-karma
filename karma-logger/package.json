{
  "name": "karma-logger",
  "version": "0.1.0",
  "description": "CLI tool for tracking Claude Code session metrics and costs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "karma": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "metrics",
    "cost-tracking",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@inkjs/ui": "^2.0.0",
    "asciichart": "^1.5.25",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "hono": "^4.11.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/asciichart": "^1.5.8",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
